#!/usr/bin/env bash
# Fails open: any error here must never block a commit.

# Bump the homepage footer's "最後更新" date to today on every commit.
if [ -f index.html ] && grep -q "最後更新：" index.html 2>/dev/null; then
  today=$(date +%Y-%m-%d)
  sed -E -i.bak "s/最後更新：[0-9]{4}-[0-9]{2}-[0-9]{2}/最後更新：$today/" index.html 2>/dev/null \
    && rm -f index.html.bak \
    && git add index.html 2>/dev/null \
    && echo "pre-commit: bumped index.html date to $today"
fi

exit 0
